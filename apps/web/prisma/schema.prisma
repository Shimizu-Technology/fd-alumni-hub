generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tournament {
  id        String              @id @default(cuid())
  name      String
  year      Int
  startDate DateTime
  endDate   DateTime
  status    TournamentStatus    @default(upcoming)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  articles  ArticleLink[]
  ingest    ContentIngestItem[]
  games     Game[]
  media     MediaAsset[]
  sponsors  Sponsor[]
  standings Standing[]
  teams     Team[]

  @@unique([year, name])
  @@index([year, status])
}

model Team {
  id             String     @id @default(cuid())
  tournamentId   String
  classYearLabel String
  displayName    String
  division       String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  awayGames      Game[]     @relation("AwayTeam")
  homeGames      Game[]     @relation("HomeTeam")
  standings      Standing[]
  tournament     Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, displayName], map: "Team_tournament_displayName_key")
  @@index([tournamentId, division], map: "Team_tournament_division_idx")
}

model Game {
  id           String     @id @default(cuid())
  tournamentId String
  homeTeamId   String
  awayTeamId   String
  startTime    DateTime
  venue        String?
  status       GameStatus @default(scheduled)
  homeScore    Int?
  awayScore    Int?
  streamUrl    String?
  ticketUrl    String?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  /// Division this game belongs to (e.g. "Maroon", "Gold", "Platinum"). Null = derive from teams.
  division     String?
  /// Bracket stage code for playoffs. Examples: MP, WMP, GP, WGP, PP, WPP, QF, SF, F
  bracketCode  String?
  awayTeam     Team       @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeTeam     Team       @relation("HomeTeam", fields: [homeTeamId], references: [id])
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([tournamentId, division], map: "Game_tournament_division_idx")
  @@index([tournamentId, startTime], map: "Game_tournament_startTime_idx")
}

model Standing {
  id            String     @id @default(cuid())
  tournamentId  String
  teamId        String
  wins          Int        @default(0)
  losses        Int        @default(0)
  pointsFor     Int        @default(0)
  pointsAgainst Int        @default(0)
  updatedAt     DateTime   @updatedAt
  team          Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, teamId], map: "Standing_tournament_team_key")
  @@index([tournamentId, wins, losses], map: "Standing_tournament_wins_losses_idx")
}

model ArticleLink {
  id           String     @id @default(cuid())
  tournamentId String
  title        String
  source       String
  url          String
  publishedAt  DateTime?
  createdAt    DateTime   @default(now())
  imageUrl     String?
  excerpt      String?
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId, publishedAt], map: "ArticleLink_tournament_publishedAt_idx")
}

model Sponsor {
  id           String     @id @default(cuid())
  tournamentId String
  name         String
  logoUrl      String?
  targetUrl    String?
  tier         String?
  active       Boolean    @default(true)
  position     Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId, active, position], map: "Sponsor_tournament_active_position_idx")
}

model MediaAsset {
  id           String     @id @default(cuid())
  tournamentId String
  source       String
  title        String
  imageUrl     String
  articleUrl   String?
  caption      String?
  tags         String?
  takenAt      DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId, source, takenAt])
}

model ContentIngestItem {
  id           String       @id @default(cuid())
  tournamentId String
  kind         IngestKind
  status       IngestStatus @default(pending)
  source       String
  title        String
  url          String
  imageUrl     String?
  excerpt      String?
  confidence   String?
  notes        String?
  importedToId String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  tournament   Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId, status, kind])
  @@index([source, status])
}

enum TournamentStatus {
  upcoming
  live
  completed
}

enum GameStatus {
  scheduled
  live
  final
}

enum IngestStatus {
  pending
  approved
  rejected
}

enum IngestKind {
  article
  media
}
